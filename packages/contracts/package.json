{
  "name": "@saga-standard/contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/ts"
  ],
  "scripts": {
    "build": "forge build && tsup",
    "build:sol": "forge build",
    "build:ts": "tsup",
    "test": "pnpm test:sol && pnpm test:ts",
    "test:ts": "vitest run",
    "test:gas": "forge test --gas-report",
    "typecheck": "tsc --noEmit",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "deploy:testnet": "forge script script/Deploy.s.sol --rpc-url base_sepolia --broadcast --verify",
    "clean": "forge clean && rm -rf dist",
    "test:sol": "forge test -vvv"
  },
  "dependencies": {
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "author": "Epic Digital Interactive Media LLC",
  "license": "Apache-2.0"
}
