    "chalk": "^5.4.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
