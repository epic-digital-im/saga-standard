{
  "name": "@epicdm/saga-cli",
  "version": "0.1.0",
  "description": "SAGA CLI — collect, export, import, and manage agent state",
  "type": "module",
  "bin": {
    "saga": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
