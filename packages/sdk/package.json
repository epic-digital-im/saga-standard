{
  "name": "@epicdm/saga-sdk",
  "version": "0.1.0",
  "description": "SAGA SDK — validate, assemble, sign, encrypt, and package SAGA documents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx,.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "viem": "^2.30.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "archiver": "^7.0.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/yauzl": "^2.10.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "author": "Epic Digital Interactive Media LLC",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epic-digital-im/saga-standard.git",
    "directory": "packages/sdk"
  }
}
