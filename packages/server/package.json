{
  "name": "@epicdm/saga-server",
  "version": "0.1.0",
  "description": "SAGA reference server — Cloudflare Worker implementing Appendix D",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply saga-registry --local",
    "lint": "eslint src/ --ext .ts,.tsx,.js"
  },
  "dependencies": {
    "@epicdm/saga-sdk": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^11.10.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  },
  "author": "Epic Digital Interactive Media LLC",
  "license": "Apache-2.0"
}
