{
  "name": "@epicdm/saga-crypto",
  "version": "0.1.0",
  "description": "SAGA cryptographic primitives — KeyRing, NaCl encryption, encrypted store",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src/ --ext .ts,.tsx,.js"
  },
  "dependencies": {
    "@epicdm/flowstate-crypto": "^1.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "author": "Epic Digital Interactive Media LLC",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epic-digital-im/saga-standard.git",
    "directory": "packages/saga-crypto"
  }
}
