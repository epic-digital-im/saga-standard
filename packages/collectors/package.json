{
  "name": "@epicdm/saga-collectors",
  "version": "0.1.0",
  "description": "SAGA collectors — extract agent state from Claude Code, OpenClaw, and other local sources",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx,.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@epicdm/saga-sdk": "workspace:*",
    "better-sqlite3": "^11.8.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "author": "Epic Digital Interactive Media LLC",
  "license": "Apache-2.0"
}
